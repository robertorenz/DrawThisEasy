      "isDeleted": false,
      "boundElements": [],
      "updated": 1774354332150,
      "link": null,
      "locked": false,
      "text": "1. Insert --> Sí mi registro tiene un userId LOCAL --> Nuevo Registro sin sincronizar con Microsoft --> Crear uno nuevo\n2. Update --> Si mi registro tiene SyncStatus=Local y Tiene lastSyncedAt --> SyncStatus = Synced \n3. Delete --> Si mi registro tiene SyncStatus=Local y Tiene lastSyncedAt  y DeletedTimeStamp > 0 --> SyncStatus = Synced ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Insert --> Sí mi registro tiene un userId LOCAL --> Nuevo Registro sin sincronizar con Microsoft --> Crear uno nuevo\n2. Update --> Si mi registro tiene SyncStatus=Local y Tiene lastSyncedAt --> SyncStatus = Synced \n3. Delete --> Si mi registro tiene SyncStatus=Local y Tiene lastSyncedAt  y DeletedTimeStamp > 0 --> SyncStatus = Synced ",
      "autoResize": true,
      "lineHeight": 1.25
    },
