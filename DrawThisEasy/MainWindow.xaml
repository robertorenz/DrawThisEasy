<Window x:Class="DrawThisEasy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DrawThisEasy.Controls"
        Title="DrawThisEasy"
        Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Focusable="True"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="52"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- ====== Top bar ====== -->
    <Border x:Name="TopBar" Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
      <Grid Margin="16,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Left: menu bar -->
        <Menu Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center">
          <MenuItem x:Name="MnuFile" Header="_File" Style="{StaticResource TopMenuItem}">
            <MenuItem x:Name="MnuFileNew"       Header="_New"            InputGestureText="Ctrl+N" Click="BtnNew_Click"/>
            <MenuItem x:Name="MnuFileTemplates" Header="_Templates..."                              Click="BtnTemplates_Click"/>
            <MenuItem x:Name="MnuFileCloud"     Header="_Cloud Services..."                          Click="BtnCloud_Click"/>
            <Separator/>
            <MenuItem x:Name="MnuFileOpen"      Header="_Open..."        InputGestureText="Ctrl+O" Click="BtnOpen_Click"/>
            <MenuItem x:Name="MnuFileRecent"    Header="Open _Recent"/>
            <MenuItem x:Name="MnuFileImportExcalidraw" Header="_Import from Excalidraw..."           Click="BtnImportExcalidraw_Click"/>
            <MenuItem x:Name="MnuFileSave"      Header="_Save..."        InputGestureText="Ctrl+S" Click="BtnSave_Click"/>
            <MenuItem x:Name="MnuFileExport"    Header="_Export PNG..."  InputGestureText="Ctrl+E" Click="BtnExport_Click"/>
            <MenuItem x:Name="MnuFileExportExcalidraw" Header="Export to _Excalidraw..." Click="BtnExportExcalidraw_Click"/>
            <MenuItem x:Name="MnuFileExportDrawio"     Header="Export to _draw.io..."    Click="BtnExportDrawio_Click"/>
            <MenuItem x:Name="MnuFileExportMermaid"    Header="Export to _Mermaid..."    Click="BtnExportMermaid_Click"/>
            <Separator/>
            <MenuItem x:Name="MnuFileExit"      Header="E_xit"                                     Click="MnuExit_Click"/>
          </MenuItem>
          <MenuItem x:Name="MnuEdit" Header="_Edit" Style="{StaticResource TopMenuItem}">
            <MenuItem x:Name="MnuEditUndo"      Header="_Undo"      InputGestureText="Ctrl+Z" Click="MnuUndo_Click"/>
            <MenuItem x:Name="MnuEditRedo"      Header="_Redo"      InputGestureText="Ctrl+Y" Click="MnuRedo_Click"/>
            <Separator/>
            <MenuItem x:Name="MnuEditCut"       Header="Cu_t"       InputGestureText="Ctrl+X" Click="MnuCut_Click"/>
            <MenuItem x:Name="MnuEditCopy"      Header="_Copy"      InputGestureText="Ctrl+C" Click="MnuCopy_Click"/>
            <MenuItem x:Name="MnuEditPaste"     Header="_Paste"     InputGestureText="Ctrl+V" Click="MnuPaste_Click"/>
            <MenuItem x:Name="MnuEditDup"       Header="_Duplicate" InputGestureText="Ctrl+D" Click="BtnDup_Click"/>
            <MenuItem x:Name="MnuEditDelete"    Header="De_lete"    InputGestureText="Del"    Click="BtnDel_Click"/>
            <Separator/>
            <MenuItem x:Name="MnuEditSelectAll" Header="Select _All" InputGestureText="Ctrl+A" Click="MnuSelectAll_Click"/>
            <Separator/>
            <MenuItem x:Name="MnuEditInsertImage" Header="Insert _Image..." Click="BtnInsertImage_Click"/>
            <Separator/>
            <MenuItem x:Name="MnuEditPreferences" Header="_Preferences..." Click="BtnPreferences_Click"/>
          </MenuItem>
          <MenuItem x:Name="MnuView" Header="_View" Style="{StaticResource TopMenuItem}">
            <MenuItem x:Name="MnuViewZoomIn"    Header="Zoom _In"      Click="BtnZoomIn_Click"/>
            <MenuItem x:Name="MnuViewZoomOut"   Header="Zoom _Out"     Click="BtnZoomOut_Click"/>
            <MenuItem x:Name="MnuViewZoomReset" Header="_Reset Zoom"   Click="BtnZoomReset_Click"/>
            <MenuItem x:Name="MnuViewFreeSpace" Header="Go to _Free Space" Click="BtnGoToFreeSpace_Click"/>
            <Separator/>
            <MenuItem x:Name="MnuViewClearGuides" Header="Clear _Guides" Click="MnuClearGuides_Click"/>
            <Separator/>
            <MenuItem x:Name="MnuViewToolbars" Header="_Toolbars">
              <MenuItem x:Name="MnuViewShowMain" Header="Show _Main Toolbar" IsCheckable="True" Click="MnuToggleMainToolbar_Click"/>
              <MenuItem x:Name="MnuViewShowFavorites" Header="Show _Favorites Toolbar" IsCheckable="True" Click="MnuToggleFavoritesToolbar_Click"/>
              <Separator/>
              <MenuItem x:Name="MnuViewCustomizeFavorites" Header="_Customize Favorites..." Click="BtnCustomizeFavorites_Click"/>
              <MenuItem x:Name="MnuViewResetToolbars" Header="_Reset Toolbars to Defaults" Click="MnuResetToolbars_Click"/>
            </MenuItem>
          </MenuItem>
          <MenuItem x:Name="MnuLang" Header="_Language" Style="{StaticResource TopMenuItem}">
            <MenuItem x:Name="MnuLangEn" Header="English" IsCheckable="True" Click="MnuLangEn_Click"/>
            <MenuItem x:Name="MnuLangEs" Header="Español" IsCheckable="True" Click="MnuLangEs_Click"/>
          </MenuItem>
          <MenuItem x:Name="MnuHelp" Header="_Help" Style="{StaticResource TopMenuItem}">
            <MenuItem x:Name="MnuHelpManual"    Header="_User Manual..."        InputGestureText="F1" Click="BtnManual_Click"/>
            <MenuItem x:Name="MnuHelpShortcuts" Header="_Keyboard Shortcuts..." InputGestureText="?"  Click="BtnHelp_Click"/>
          </MenuItem>
        </Menu>

        <!-- Right side: zoom + lang/help icons -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="#FFF1F5F9" CornerRadius="6" Padding="2" Margin="0,0,8,0">
            <StackPanel Orientation="Horizontal">
              <Button x:Name="BtnZoomOut"   Style="{StaticResource IconButton}" Content="−" Click="BtnZoomOut_Click"   Width="28" Height="26"/>
              <Button x:Name="BtnZoomReset" Style="{StaticResource IconButton}"             Click="BtnZoomReset_Click" Width="50" Height="26">
                <TextBlock x:Name="ZoomLabel" Text="100%" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
              </Button>
              <Button x:Name="BtnZoomIn"    Style="{StaticResource IconButton}" Content="+" Click="BtnZoomIn_Click"    Width="28" Height="26"/>
            </StackPanel>
          </Border>
          <Button x:Name="BtnLang" Style="{StaticResource IconButton}" Click="BtnLang_Click" Content="EN" MinWidth="40" FontWeight="SemiBold"/>
          <Button x:Name="BtnHelp" Style="{StaticResource IconButton}" Click="BtnHelp_Click" Content="?"/>
        </StackPanel>

        <!-- Right-most: brand -->
        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
          <Grid Width="28" Height="28" Margin="0,0,10,0">
            <Rectangle Width="11" Height="9" RadiusX="2" RadiusY="2" Fill="#0EA5E9" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2,4,0,0"/>
            <Rectangle Width="11" Height="9" RadiusX="2" RadiusY="2" Fill="#14B8A6" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,2,0"/>
            <Rectangle Width="11" Height="9" RadiusX="2" RadiusY="2" Fill="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
          </Grid>
          <TextBlock Text="DrawThisEasy" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ====== Tool strip (secondary toolbar) ====== -->
    <Border x:Name="MainToolStripBorder" Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Height="44">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="12,0">
        <StackPanel x:Name="ToolStrip" Orientation="Horizontal" VerticalAlignment="Center"/>
      </ScrollViewer>
    </Border>

    <!-- ====== Favorites strip (user-curated toolbar; collapses when empty/disabled) ====== -->
    <Border x:Name="FavoritesStripBorder" Grid.Row="2" Background="#FFF8FAFC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Height="40" Visibility="Collapsed">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="FavoritesStripLabel" Grid.Column="0" Text="Favorites" VerticalAlignment="Center" Margin="14,0,10,0"
                   FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="0,0,8,0">
          <StackPanel x:Name="FavoritesStrip" Orientation="Horizontal" VerticalAlignment="Center"/>
        </ScrollViewer>
        <Button x:Name="BtnCustomizeFavorites" Grid.Column="2" Style="{StaticResource IconButton}"
                Content="⚙" FontSize="13" Margin="0,0,10,0"
                Click="BtnCustomizeFavorites_Click"/>
      </Grid>
    </Border>

    <!-- ====== Body: palette + canvas ====== -->
    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="PaletteCol" Width="220"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Palette -->
      <Border x:Name="PaletteBorder" Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="10,12,10,12" x:Name="PaletteStack"/>
        </ScrollViewer>
      </Border>

      <!-- Canvas area: document tabs + canvas host -->
      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Document tab strip -->
        <Border x:Name="TabStripBorder" Grid.Row="0" Background="#FFF1F5F9" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel x:Name="TabStrip" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="8,0,8,0"/>
          </ScrollViewer>
        </Border>

        <!-- Rulers framing the canvas; drag from a ruler onto the canvas to drop a guide -->
        <Grid x:Name="RulerGrid" Grid.Row="1">
          <Grid.RowDefinitions>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Border Grid.Row="0" Grid.Column="0" Background="#FFF1F5F9" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,1"/>
          <Border Grid.Row="0" Grid.Column="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                  ClipToBounds="True" Cursor="SizeNS"
                  MouseLeftButtonDown="RulerTop_MouseDown" MouseMove="Ruler_MouseMove" MouseLeftButtonUp="Ruler_MouseUp">
            <Canvas x:Name="RulerTop" Background="Transparent"/>
          </Border>
          <Border Grid.Row="1" Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                  ClipToBounds="True" Cursor="SizeWE"
                  MouseLeftButtonDown="RulerLeft_MouseDown" MouseMove="Ruler_MouseMove" MouseLeftButtonUp="Ruler_MouseUp">
            <Canvas x:Name="RulerLeft" Background="Transparent"/>
          </Border>

          <!-- Canvas host: every open diagram lives here; only the active one is visible -->
          <Grid Grid.Row="1" Grid.Column="1">
          <Grid x:Name="CanvasHost"/>

          <!-- Scrollbars (wheel scrolls; these reflect/drive the canvas position) -->
          <ScrollBar x:Name="VScroll" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                     Width="14" Margin="0,0,0,42" Scroll="VScroll_Scroll"/>
          <ScrollBar x:Name="HScroll" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                     Height="14" Margin="0,0,14,28" Scroll="HScroll_Scroll"/>

        <!-- Status bar (bottom overlay) -->
        <Border x:Name="StatusBar" VerticalAlignment="Bottom" Background="#F2FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Height="28">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
            <TextBlock x:Name="StatusTool" Text="Select" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="·" Margin="8,0" Foreground="{StaticResource TextMutedBrush}"/>
            <TextBlock x:Name="StatusHint" Text="Click a tool, then click the canvas. Hold Space to pan." FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
          </StackPanel>
        </Border>

        <!-- Inspector (top right floating) -->
        <Border x:Name="Inspector"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,16,22,0"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="12"
                Width="240"
                Padding="12"
                Visibility="Collapsed">
          <Border.Effect>
            <DropShadowEffect Color="#0F172A" Opacity="0.12" BlurRadius="16" ShadowDepth="2"/>
          </Border.Effect>
          <StackPanel>
            <DockPanel Margin="0,2,0,6">
              <TextBlock x:Name="LblFill" Text="FILL" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Width="48" VerticalAlignment="Center"/>
              <WrapPanel x:Name="FillSwatches" Orientation="Horizontal"/>
            </DockPanel>
            <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,4"/>
            <DockPanel Margin="0,6,0,6">
              <TextBlock x:Name="LblStroke" Text="STROKE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Width="48" VerticalAlignment="Center"/>
              <WrapPanel x:Name="StrokeSwatches" Orientation="Horizontal"/>
            </DockPanel>
            <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,4"/>
            <StackPanel x:Name="TextSection" Margin="0,2,0,0"/>
            <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,4"/>
            <UniformGrid Columns="4" Margin="0,6,0,0">
              <Button x:Name="BtnFront" Style="{StaticResource MiniButton}" Content="Front"  Click="BtnFront_Click" Margin="0,0,4,0"/>
              <Button x:Name="BtnBack"  Style="{StaticResource MiniButton}" Content="Back"   Click="BtnBack_Click"  Margin="0,0,4,0"/>
              <Button x:Name="BtnDup"   Style="{StaticResource MiniButton}" Content="Dup"    Click="BtnDup_Click"   Margin="0,0,4,0"/>
              <Button x:Name="BtnDel"   Style="{StaticResource MiniButton}" Content="Delete" Click="BtnDel_Click">
                <Button.Background><SolidColorBrush Color="#FFFEF2F2"/></Button.Background>
                <Button.Foreground><SolidColorBrush Color="#FFEF4444"/></Button.Foreground>
              </Button>
            </UniformGrid>
          </StackPanel>
        </Border>

        <!-- Presentation panel (top-left floating) -->
        <Border x:Name="PresentPanel"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="22,16,0,0"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="12" Width="250" Padding="12" Visibility="Collapsed">
          <Border.Effect>
            <DropShadowEffect Color="#0F172A" Opacity="0.12" BlurRadius="16" ShadowDepth="2"/>
          </Border.Effect>
          <StackPanel>
            <DockPanel Margin="0,0,0,8">
              <Button x:Name="BtnClosePresentPanel" DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                      Content="✕" Width="22" Height="22" Click="BtnClosePresentPanel_Click"/>
              <TextBlock x:Name="PresentTitle" Text="PRESENTATION" FontSize="10" FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
            </DockPanel>
            <Button x:Name="BtnMarkScreen" Style="{StaticResource GhostButton}" Content="Mark current view"
                    Click="BtnMarkScreen_Click" Margin="0,0,0,4" HorizontalContentAlignment="Center"/>
            <Button x:Name="BtnAddFreeScreen" Style="{StaticResource GhostButton}" Content="Add empty screen"
                    Click="BtnAddFreeScreen_Click" Margin="0,0,0,8" HorizontalContentAlignment="Center"/>
            <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel x:Name="PresentList"/>
            </ScrollViewer>
            <TextBlock x:Name="PresentEmptyHint" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                       TextWrapping="Wrap" Margin="2,2,2,6"
                       Text="No screens yet. Frame an area and Mark it, or add an empty screen."/>
            <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,4"/>
            <TextBlock x:Name="LblPresentTransition" Text="TRANSITION" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,4"/>
            <ComboBox x:Name="PresentTransitionCombo" Height="26" Margin="0,0,0,8"
                      SelectionChanged="PresentTransitionCombo_Changed"/>
            <TextBlock x:Name="LblPresentBg" Text="BACKGROUND" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,4"/>
            <WrapPanel x:Name="PresentBgSwatches" Margin="0,0,0,8"/>
            <Button x:Name="BtnStartPresent" Style="{StaticResource PrimaryButton}" Content="Start Presenting"
                    Click="BtnStartPresent_Click"/>
          </StackPanel>
        </Border>

        <!-- Current-screen indicator shown while presenting -->
        <Border x:Name="PresentIndicator"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,24,24" Padding="14,7"
                Background="#CC0F172A" CornerRadius="16"
                Visibility="Collapsed" IsHitTestVisible="False">
          <Border.Effect>
            <DropShadowEffect Color="#0F172A" Opacity="0.35" BlurRadius="14" ShadowDepth="2"/>
          </Border.Effect>
          <TextBlock x:Name="PresentIndicatorText" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
        </Border>
          </Grid>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
</Window>
