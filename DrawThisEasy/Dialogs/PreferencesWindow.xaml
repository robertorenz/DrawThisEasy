<Window x:Class="DrawThisEasy.Dialogs.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Width="400" SizeToContent="Height">
  <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect Color="#0F172A" Opacity="0.35" BlurRadius="40" ShadowDepth="6"/>
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
        <Grid Margin="18,14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" x:Name="TitleText" Text="Preferences" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Style="{StaticResource IconButton}" Click="Close_Click" Content="✕" FontSize="14" Foreground="{StaticResource TextMutedBrush}"/>
        </Grid>
      </Border>

      <StackPanel Grid.Row="1" Margin="18,14,18,16">
        <TextBlock x:Name="LblConnector" Text="DEFAULT CONNECTOR" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
        <DockPanel Margin="0,0,0,8">
          <TextBlock x:Name="LblRouting" Text="Routing" Width="110" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
          <ComboBox x:Name="CmbRouting"/>
        </DockPanel>
        <DockPanel>
          <TextBlock x:Name="LblStroke" Text="Stroke" Width="110" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
          <ComboBox x:Name="CmbStroke"/>
        </DockPanel>

        <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,14"/>

        <CheckBox x:Name="ChkSnap" Content="Snap to objects and guides" Foreground="{StaticResource TextBrush}"/>

        <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,14"/>

        <DockPanel>
          <TextBlock x:Name="LblUnits" Text="Ruler units" Width="110" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
          <ComboBox x:Name="CmbUnits"/>
        </DockPanel>
      </StackPanel>

      <Border Grid.Row="2" Background="#FFF8FAFC" CornerRadius="0,0,12,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,10">
          <Button x:Name="BtnCancel" Content="Cancel" Style="{StaticResource GhostButton}" Click="Close_Click" MinWidth="92" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0"/>
          <Button x:Name="BtnSave" Content="Save" Style="{StaticResource PrimaryButton}" Click="Save_Click" MinWidth="92"/>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
