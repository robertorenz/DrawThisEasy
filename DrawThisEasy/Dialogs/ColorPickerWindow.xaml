<Window x:Class="DrawThisEasy.Dialogs.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Width="360" SizeToContent="Height">
  <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect Color="#0F172A" Opacity="0.35" BlurRadius="40" ShadowDepth="6"/>
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
        <Grid Margin="18,14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" x:Name="TitleText" Text="Color picker" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Style="{StaticResource IconButton}" Click="Cancel_Click" Content="✕" FontSize="14" Foreground="{StaticResource TextMutedBrush}"/>
        </Grid>
      </Border>

      <!-- Body -->
      <StackPanel Grid.Row="1" Margin="18,16,18,16">

        <!-- Saturation-Value picker -->
        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" SnapsToDevicePixels="True">
          <Canvas x:Name="SVPicker" Width="320" Height="180" Background="Transparent"
                  MouseLeftButtonDown="SVPicker_MouseDown"
                  MouseMove="SVPicker_MouseMove"
                  MouseLeftButtonUp="SVPicker_MouseUp"
                  ClipToBounds="True">
            <Rectangle x:Name="SVBase" Width="320" Height="180" IsHitTestVisible="False"/>
            <Rectangle Width="320" Height="180" IsHitTestVisible="False">
              <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Offset="0" Color="#00000000"/>
                  <GradientStop Offset="1" Color="#FF000000"/>
                </LinearGradientBrush>
              </Rectangle.Fill>
            </Rectangle>
            <Ellipse x:Name="SVCursor" Width="14" Height="14" Stroke="White" StrokeThickness="2" Fill="Transparent" IsHitTestVisible="False">
              <Ellipse.Effect>
                <DropShadowEffect Color="Black" Opacity="0.45" BlurRadius="3" ShadowDepth="0"/>
              </Ellipse.Effect>
            </Ellipse>
          </Canvas>
        </Border>

        <!-- Hue slider -->
        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,10,0,0" SnapsToDevicePixels="True">
          <Canvas x:Name="HueSlider" Width="320" Height="18" Background="Transparent"
                  MouseLeftButtonDown="Hue_MouseDown"
                  MouseMove="Hue_MouseMove"
                  MouseLeftButtonUp="Hue_MouseUp"
                  ClipToBounds="True">
            <Rectangle Width="320" Height="18" IsHitTestVisible="False">
              <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                  <GradientStop Offset="0.000" Color="#FFFF0000"/>
                  <GradientStop Offset="0.167" Color="#FFFFFF00"/>
                  <GradientStop Offset="0.333" Color="#FF00FF00"/>
                  <GradientStop Offset="0.500" Color="#FF00FFFF"/>
                  <GradientStop Offset="0.667" Color="#FF0000FF"/>
                  <GradientStop Offset="0.833" Color="#FFFF00FF"/>
                  <GradientStop Offset="1.000" Color="#FFFF0000"/>
                </LinearGradientBrush>
              </Rectangle.Fill>
            </Rectangle>
            <Rectangle x:Name="HueCursor" Width="6" Height="22" Margin="0,-2,0,0" Stroke="White" StrokeThickness="2" Fill="Transparent" IsHitTestVisible="False">
              <Rectangle.Effect>
                <DropShadowEffect Color="Black" Opacity="0.45" BlurRadius="3" ShadowDepth="0"/>
              </Rectangle.Effect>
            </Rectangle>
          </Canvas>
        </Border>

        <!-- Hex + preview -->
        <Grid Margin="0,14,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" x:Name="LblHex" Text="Hex" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
          <TextBox Grid.Column="1" x:Name="HexInput" Height="30" Padding="8,4" FontFamily="Consolas" FontSize="13" VerticalContentAlignment="Center"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" KeyDown="HexInput_KeyDown" LostFocus="HexInput_LostFocus"/>
          <Border Grid.Column="2" Width="44" Height="30" Margin="10,0,0,0" CornerRadius="4"
                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Rectangle x:Name="PreviewSwatch" Fill="White"/>
          </Border>
        </Grid>

        <!-- Standard palette -->
        <TextBlock x:Name="LblStandard" Text="STANDARD COLORS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,8"/>
        <ItemsControl x:Name="StandardGrid">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="10"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
        </ItemsControl>
      </StackPanel>

      <!-- Footer -->
      <Border Grid.Row="2" Background="#FFF8FAFC" CornerRadius="0,0,12,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,10">
          <Button x:Name="BtnCancel" Content="Cancel" Style="{StaticResource GhostButton}" Click="Cancel_Click" MinWidth="92" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
          <Button x:Name="BtnApply"  Content="Apply"  Style="{StaticResource PrimaryButton}" Click="Apply_Click" MinWidth="92" Margin="8,0,0,0"/>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
