<Window x:Class="DrawThisEasy.Dialogs.ManualWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Width="860" SizeToContent="Height">
  <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect Color="#0F172A" Opacity="0.35" BlurRadius="40" ShadowDepth="6"/>
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
        <Grid Margin="18,14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock x:Name="TitleText" Text="User manual" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
            <TextBlock x:Name="SubtitleText" Text="" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <Button Grid.Column="1" Style="{StaticResource IconButton}" Click="Close_Click" Content="✕" FontSize="14" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Top"/>
        </Grid>
      </Border>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="184"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Chapter navigation -->
        <Border Grid.Column="0" Background="#FFF8FAFC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
          <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560">
            <StackPanel x:Name="TocStack" Margin="10,14,8,14"/>
          </ScrollViewer>
        </Border>

        <ScrollViewer x:Name="BodyScroll" Grid.Column="1" MaxHeight="560" VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="ManualStack" Margin="24,18,24,22"/>
        </ScrollViewer>
      </Grid>

      <Border Grid.Row="2" Background="#FFF8FAFC" CornerRadius="0,0,12,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,10">
          <Button x:Name="BtnClose" Content="Close" Style="{StaticResource PrimaryButton}" Click="Close_Click" MinWidth="92"/>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
